# ─────────────────────────────────────────────
# AI 同声传译助手 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ─────────────────────────────────────────────

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# ──── 音频采集 ────
SAMPLE_RATE=16000
CHANNELS=1
SAMPLE_WIDTH=2
FRAME_DURATION_MS=20
# 留空则使用系统默认输入设备（取消注释并填入设备索引以选择特定设备）
# AUDIO_DEVICE_INDEX=0

# ──── VAD 语音活动检测 ────
# 0=宽松, 3=最激进
VAD_MODE=1
# VAD 处理帧大小 (10, 20, 30 ms)
VAD_FRAME_MS=30
# 语音结束静音判定阈值 (ms)
SILENCE_DURATION_MS=800

# ──── ASR 语音识别 ────
ASR_MODEL_SIZE=base
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8

# ──── LLM 翻译 (后续阶段使用) ────
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 如果使用 Anthropic:
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# ──── 滑动窗口修正 ────
ENABLE_CORRECTION=true
CORRECTION_WINDOW_SIZE=5
CORRECTION_CONFIDENCE_THRESHOLD=0.75

# ──── WebSocket 服务 ────
WS_HOST=0.0.0.0
WS_PORT=8765
